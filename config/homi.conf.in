# This configuration file should be written in TOML format.

# CRITICAL = 0, WARNING = 1, NOTICE = 2, INFO = 3, DEBUG = 4
log_level = 2

# Devices is a list of tables with 'uri' and optionally 'nsid' (xNVMe backend).
# Example:
# devices = [{ uri = "0000:01:00.0", nsid = 1 }]
devices = []

# IPC socket
ipc_socket = "/run/homi/homi.sock"

[xnvme]
# Available backends: "linux", "upcie"
be = "linux"
# Arbitrary, but unique shm_id
shm_id = 67

[xal]
# xfs = 1, fiemap = 2
backend = 2
# none = 0, dirty detection = 1, extent update = 2
watchmode = 2
# traverse = 0, hashmap = 1
file_lookupmode = 0
